# Copy to .env and adjust. Everything defaults to the local docker-compose stack.

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=copilot
POSTGRES_PASSWORD=copilot
POSTGRES_DB=platform_copilot

# OpenSearch
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_INDEX=platform_docs

# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Redis
REDIS_URL=redis://localhost:6379/0

# Embeddings (optional; Jina AI). Leave blank to use a local embedding model.
JINA_API_KEY=

# Langfuse (optional; observability). Added in M5.
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Telegram (optional; on-call bot). Added in M6.
TELEGRAM_BOT_TOKEN=
