# Copy to .env and adjust. Everything defaults to the local docker-compose stack.

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=copilot
POSTGRES_PASSWORD=copilot
POSTGRES_DB=platform_copilot

# OpenSearch
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_INDEX=platform_docs

# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Agent: back /ask with the LangGraph agent (guardrail -> grade -> rewrite -> retry).
# Costs ~3 LLM round-trips per request; set false for single-shot RAG.
USE_AGENT=true

# Redis (REDIS_HOST_PORT is the host-side port compose publishes)
REDIS_HOST_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Embeddings (optional; Jina AI). Leave blank to use the local placeholder embedder.
JINA_API_KEY=

# Langfuse (optional; tracing + cost). Start it with:
#   docker compose --profile observability up -d langfuse-db langfuse
# then create a project at http://localhost:3001 and paste the keys below.
# Without keys the app uses a NullSink and records nothing.
LANGFUSE_PORT=3001
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Telegram (optional; on-call bot). Create a bot with @BotFather to get a token.
TELEGRAM_BOT_TOKEN=
